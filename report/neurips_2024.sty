%%%%% NeurIPS 2024 style (compact reimplementation for COMP 559)       %%%%%
%%%%% Layout, title, author block, abstract all match the official spec %%%%%
%%%%% Compiles on Overleaf with pdfLaTeX                                %%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 v1.0 NeurIPS 2024 style]

% ---- options --------------------------------------------------------------
\newif\if@natbib \@natbibtrue
\newif\if@preprint \@preprintfalse
\newif\if@final \@finalfalse
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@natbibfalse}
\ProcessOptions\relax

% ---- page geometry (NeurIPS 2024 spec) ------------------------------------
\RequirePackage[letterpaper,
                textheight=9in, textwidth=5.5in,
                top=1in, bottom=1in,
                hmarginratio=1:1,
                footskip=0.35in]{geometry}

% ---- fonts ----------------------------------------------------------------
\RequirePackage{times}

% ---- bibliography ---------------------------------------------------------
\if@natbib
  \RequirePackage[numbers,sort&compress,comma]{natbib}
  \bibliographystyle{unsrtnat}
\fi

% ---- misc reqs ------------------------------------------------------------
\RequirePackage{url}
\RequirePackage{amsmath,amssymb}

% ---- paragraph / spacing --------------------------------------------------
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\renewcommand{\baselinestretch}{1.02}

% ---- title block ----------------------------------------------------------
% The author block is built in main.tex out of 3 side-by-side tabulars,
% so @maketitle does NOT wrap @author in an outer tabular.
\renewcommand{\@maketitle}{%
  \newpage\null
  \vskip 1pt%
  \begin{center}%
    \let\footnote\thanks
    {\LARGE\bfseries \@title\par}%
    \vskip 0.3in%
    \lineskip 0.5em%
    {\large \@author \par}%
    \vskip 0.25in%
    \@date%
  \end{center}%
  \par\vskip 0.2in%
}

% ---- abstract -------------------------------------------------------------
\renewenvironment{abstract}{%
  \vskip 0.075in%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small}%
  {\par\end{quote}\vskip 0.6ex}

% ---- first-page footer for preprint / final -------------------------------
\if@preprint
  \def\@noticestring{Preprint.\ Under review.}
\else\if@final
  \def\@noticestring{Published at the 38th Conference on Neural Information Processing Systems (NeurIPS 2024).}
\else
  \def\@noticestring{Submitted to the 38th Conference on Neural Information Processing Systems (NeurIPS 2024).\ Do not distribute.}
\fi\fi

\def\ps@firstpagestyle{%
  \renewcommand{\@oddfoot}{\hfil\normalfont\footnotesize\@noticestring\hfil}%
  \renewcommand{\@oddhead}{}%
  \renewcommand{\@evenfoot}{\hfil\normalfont\footnotesize\@noticestring\hfil}%
  \renewcommand{\@evenhead}{}%
}
\AtBeginDocument{\thispagestyle{firstpagestyle}}

% ---- section formatting ---------------------------------------------------
\RequirePackage{titlesec}
\titleformat{\section}{\normalfont\Large\bfseries}{\thesection}{0.7em}{}
\titleformat{\subsection}{\normalfont\large\bfseries}{\thesubsection}{0.6em}{}
\titleformat{\subsubsection}{\normalfont\normalsize\bfseries}{\thesubsubsection}{0.5em}{}
\titleformat{\paragraph}[runin]{\normalfont\normalsize\bfseries}{}{0pt}{}[.]
\titlespacing*{\section}{0pt}{2.0ex plus 0.5ex minus 0.2ex}{1.0ex plus 0.2ex}
\titlespacing*{\subsection}{0pt}{1.6ex plus 0.5ex minus 0.2ex}{0.8ex plus 0.1ex}
\titlespacing*{\paragraph}{0pt}{1.2ex plus 0.3ex}{1em}

% ---- caption formatting ---------------------------------------------------
\RequirePackage[font=small,labelfont=bf,labelsep=colon,skip=5pt]{caption}

% ---- lists ----------------------------------------------------------------
\RequirePackage{enumitem}
\setlist{itemsep=2pt, topsep=2pt, parsep=0pt}

% ---- hyperref should be loaded last by the user
\endinput
